{
  "name": "iridat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "coverage": "jest --coverage",
    "watchTest": "jest --watch",
    "pa11y": "pa11y --runner axe --runner htmlcs"
  },
  "dependencies": {
    "@cmsgov/design-system": "^13",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@redux-devtools/extension": "^4.0.0",
    "@tanstack/react-table": "^8.21.3",
    "aws-amplify": "~6.16.4",
    "date-fns": "^4.1.0",
    "font-awesome": "^4.7.0",
    "jsonpath": "^1.3.0",
    "launchdarkly-react-client-sdk": "^3.9.0",
    "mathjs": "^15.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet": "^6.1.0",
    "react-multi-select-component": "4.3.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.2",
    "redux": "5.0.1",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^3.1.0",
    "sass": "^1.99.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@vitejs/plugin-react": "6.0.1",
    "axe-core": "^4.11.3",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "pa11y": "^9.1.1",
    "redux-mock-store": "^1.5.5",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/components/**/*.{js,jsx}",
      "src/util/**/*.{js,jsx}",
      "!src/index.jsx",
      "!src/types.js",
      "!src/config.js",
      "!src/**/index.{js,jsx}",
      "!src/components/utils/statesArray.js",
      "!src/util/testing/**/*.{js,jsx}",
      "!src/actions/**/*.{js,jsx}",
      "!src/store/**/*.{js,jsx}",
      "!src/util/idLetterMarkers.js"
    ],
    "coverageReporters": [
      "json",
      [
        "lcov",
        {
          "projectRoot": "../../"
        }
      ],
      "text",
      "text-summary"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "<rootDir>/src/util/testing/styleMock.js",
      "\\.(jpg|jpeg|png|gif|webp|svg|mp4|webm|wav|mp3|m4a)$": "<rootDir>/src/util/testing/mockAsset.ts"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testEnvironment": "jsdom",
    "transformIgnorePatterns": [
      "/node_modules/(?!(uuid|@redux-devtools/extension)/)"
    ]
  }
}
