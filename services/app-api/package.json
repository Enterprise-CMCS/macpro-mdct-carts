{
  "name": "app-api",
  "version": "1.0.0",
  "description": "",
  "license": "CC0-1.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enterprise-CMCS/macpro-mdct-carts.git"
  },
  "main": "handler.js",
  "scripts": {
    "coverage": "jest --coverage",
    "test": "jest",
    "test-watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "~3.1037.0",
    "@aws-sdk/client-s3": "~3.1037.0",
    "@aws-sdk/lib-dynamodb": "~3.1037.0",
    "@aws-sdk/s3-request-presigner": "~3.1037.0",
    "jsonpath-plus": "^10.4.0",
    "jsonschema": "^1.5.0",
    "jwt-decode": "^4.0.0",
    "prince": "^1.12.4",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.13",
    "@types/sanitize-html": "^2.16.0",
    "aws-sdk-client-mock": "~4.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "handlers/**/*.{ts,tsx}",
      "libs/**/*.{ts,tsx}"
    ],
    "coverageReporters": [
      "json",
      [
        "lcov",
        {
          "projectRoot": "../../"
        }
      ],
      "text",
      "text-summary"
    ],
    "globals": {
      "isolatedModules": true
    },
    "moduleDirectories": [
      "node_modules",
      "handlers",
      "libs",
      "util"
    ],
    "setupFilesAfterEnv": [],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.build/"
    ],
    "transform": {
      "^.+\\.[tj]s$": "ts-jest"
    },
    "verbose": true
  }
}
